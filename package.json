{
  "name": "porta",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:cloud": "node scripts/dev-cloud.mjs",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @porta/web build",
    "deploy": "node scripts/deploy.mjs",
    "lint": "pnpm -r lint",
